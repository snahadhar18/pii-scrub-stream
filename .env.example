# RedactAI configuration (copy to .env). All variables use the RG_ prefix
# and __ as the nested-section delimiter. Values shown are the defaults.

# General
RG_ENVIRONMENT=development
# Comma-separated detector names to enable; empty = all discovered plugins.
# RG_DETECTORS=
RG_LOAD_ENTRY_POINT_DETECTORS=true

# Processing engine
RG_PROCESSING__WORKERS=4
RG_PROCESSING__BATCH_SIZE=256
RG_PROCESSING__QUEUE_MAXSIZE=1000
RG_PROCESSING__MAX_RETRIES=2
RG_PROCESSING__REDACTION_STRATEGY=tag        # tag | mask | hash | remove
RG_PROCESSING__REDACT_BY_DEFAULT=true

# Streaming
RG_STREAMING__BUFFER_SIZE=1000
RG_STREAMING__WORKERS=2
RG_STREAMING__SHUTDOWN_GRACE_S=5.0

# Ingestion
RG_INGESTION__CHUNK_SIZE=65536
RG_INGESTION__ENCODING=utf-8
RG_INGESTION__CSV_DELIMITER=,

# API
RG_API__HOST=0.0.0.0
RG_API__PORT=8000

# Observability
RG_OBSERVABILITY__LOG_LEVEL=INFO
RG_OBSERVABILITY__LOG_FORMAT=json            # json | text
RG_OBSERVABILITY__AUDIT_ENABLED=true
# RG_OBSERVABILITY__AUDIT_PATH=/var/log/rag-guardian/audit.log
RG_OBSERVABILITY__METRICS_ENABLED=true
